# ============================================================================
# NETWORK — uncomment EXACTLY ONE block, comment the other.
# Then restart `next dev` (env vars don't HMR).
# ============================================================================

# --- testnet ---
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_USDC_COIN_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
# NEXT_PUBLIC_TAPP_PACKAGE_ID=  # Set when the Tapp Card Move package is deployed to testnet

# --- mainnet ---
# NEXT_PUBLIC_SUI_NETWORK=mainnet
# NEXT_PUBLIC_USDC_COIN_TYPE=0xdba34672e30cb065b1f93e3ab55318768fd6fef66c15942c9f7cb846e2f900e7::usdc::USDC
# NEXT_PUBLIC_TAPP_PACKAGE_ID=  # Set when the Tapp Card Move package is deployed to mainnet


# ============================================================================
# COMMON — same across networks.
# ============================================================================

# Rails backend (B2B settlement infra) the PWA talks to.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth client_id — shared with Rails as GOOGLE_OAUTH_CLIENT_ID.
# Get from Google Cloud Console → APIs & Services → Credentials →
# OAuth 2.0 Client (Web application). Add your dev origin
# (http://localhost:3000) and production origin to "Authorized
# JavaScript origins" so the @react-oauth/google widget loads.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# Shinami: sole zkLogin provider (testnet + mainnet). SERVER-ONLY —
# never NEXT_PUBLIC_. Wallet Services don't support CORS, and these
# keys have wallet-creation + signing rights that must not ship in
# the browser. The /api/shinami/* proxies hold the active key,
# authenticate the caller via Rails JWT, rate-limit per user, and
# cache wallet lookups. Free tier covers 20k wallet creations + 40
# QPS, no card required.
#
# Shinami access keys are per-network (us1_sui_testnet_… vs
# us1_sui_mainnet_…). Configure both — the proxy auto-selects based
# on NEXT_PUBLIC_SUI_NETWORK. Sign up at dashboard.shinami.com,
# enable Wallet Services + Gas Station + Node Service for each
# network you want.
SHINAMI_API_KEY_TESTNET=
SHINAMI_API_KEY_MAINNET=

# OPTIONAL: separate Node-Service-only Shinami key, safe to ship in
# the browser. If set, the Sui RPC client uses Shinami's mainnet RPC
# as the primary with the public fullnode as fallback. If unset, we
# just use the public fullnode. Create as a separate key in the
# Shinami dashboard with ONLY Node Service rights checked.
# NEXT_PUBLIC_SHINAMI_NODE_KEY=

# Feature flags.
NEXT_PUBLIC_DEMO_LINK=0          # 1 = use mock card-link signing (skips Move call)
NEXT_PUBLIC_WALLET_MOCK=0        # 1 = use mock wallet state instead of fullnode reads

# Rails backend the PWA talks to.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Google OAuth client ID — shared with Rails as GOOGLE_OAUTH_CLIENT_ID.
# Get from Google Cloud Console → APIs & Services → Credentials →
# OAuth 2.0 Client (Web application). Add your dev origin
# (http://localhost:3000) and production origin to "Authorized
# JavaScript origins" so the @react-oauth/google widget loads.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=

# ----- Sui chain integration (Tap Card linking + top-up + revoke) -----

# Sui network the PWA + zkLogin SDK use. "testnet" | "mainnet" | "devnet".
NEXT_PUBLIC_SUI_NETWORK=testnet

# Move package ID of the deployed `rails::tapp_card` module. Get from
# the `sui client publish` output after deploying contracts/gateway.
# Leave empty + set NEXT_PUBLIC_DEMO_LINK=1 below to run the linking
# UI flow end-to-end without an actual chain call.
NEXT_PUBLIC_TAPP_PACKAGE_ID=

# Move coin type the cards are denominated in (USDC on Sui). Usually
# 0x<COIN_PACKAGE>::usdc::USDC. Used as the type-arg for create_cap.
NEXT_PUBLIC_USDC_COIN_TYPE=

# Mysten zkLogin services. Defaults point at Mysten's hosted testnet
# infra — rate-limited; self-host for production:
#   prover: github.com/MystenLabs/zklogin-prover
#   salt:   github.com/MystenLabs/zklogin-prover/tree/main/zklogin-salt-service
NEXT_PUBLIC_ZKLOGIN_PROVER_URL=https://prover-dev.mystenlabs.com/v1
NEXT_PUBLIC_ZKLOGIN_SALT_URL=https://salt.api.mystenlabs.com/get_salt

# Set to "1" to skip the Sui PTB sign during linking + management
# flows. Useful for UI hand-testing before the Move package is
# deployed. The PWA still calls Rails with stub digests so the
# server-side state machine runs end-to-end.
NEXT_PUBLIC_DEMO_LINK=1
